generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/* ======================
   ENUMS
   ====================== */

/*
 * Role — drives all access control decisions.
 * Stored directly on User (no separate roles table).
 * Three fixed levels, no dynamic creation at runtime.
 */
enum Role {
  ADMIN
  ANALYST
  VIEWER
}

/*
 * UserStatus — controls whether a user can authenticate.
 * INACTIVE = deactivated by admin.
 * SUSPENDED = temporarily blocked.
 * Checked in auth.service before issuing a JWT.
 */
enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

/*
 * TransactionType — encodes direction of money movement.
 * Amount is always positive. Type carries the sign.
 */
enum TransactionType {
  INCOME
  EXPENSE
}

/*
 * ImportJobStatus — lifecycle states for a background bulk import job.
 * PENDING     = job created, waiting in queue
 * PROCESSING  = worker has picked it up
 * COMPLETED   = all rows saved successfully
 * PARTIAL     = some rows saved, some failed (partial mode only)
 * FAILED      = unrecoverable error or atomic mode with validation errors
 */
enum ImportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
}

/* ======================
   MODELS
   ====================== */

/*
 * User
 * Central identity model. Every action in the system is attributable
 * to a user. Users are never hard deleted — use status INACTIVE instead.
 * Hard deletes would break audit log foreign keys.
 */
model User {
  id           String     @id @default(uuid())
  username     String     @unique
  email        String     @unique
  passwordHash String
  role         Role       @default(VIEWER)
  status       UserStatus @default(ACTIVE)
  mustChangePassword Boolean @default(false)
  lastLogin    DateTime?  // null = never logged in

  records    FinancialRecord[]
  auditLogs  AuditLog[]
  importJobs ImportJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([status])
}

/*
 * FinancialRecord
 * The core ledger. Every money movement is one row.
 *
 * category is stored as a plain string (e.g. "Salary", "AWS Bill").
 * There is no Category table or foreign key — this avoids JOINs in
 * aggregation queries and lets callers freely name their categories.
 * Dashboard grouping is done directly via GROUP BY category.
 *
 * Soft delete: deletedAt only — no isDeleted boolean.
 * Having both creates a split-brain bug where isDeleted = true
 * but deletedAt = null (or vice versa). One field, one truth.
 * Query active records: WHERE deletedAt IS NULL
 *
 * transactionDate has no default — callers must supply it explicitly.
 * Defaulting to now() would silently accept missing dates.
 */
model FinancialRecord {
  id              String          @id @default(uuid())
  amount          Decimal         @db.Decimal(19, 4)
  type            TransactionType
  category        String          // free-form string, e.g. "Salary", "Transport"
  transactionDate DateTime        // no default — required input
  description     String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  // Soft delete — deletedAt IS NULL means active
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([transactionDate])
  @@index([createdById])
  @@index([category])
  @@index([deletedAt])
  @@index([type])
}

/*
 * AuditLog
 * Append-only compliance trail. Never updated, never deleted.
 * One row per write action anywhere in the system.
 *
 * userId is optional — if a user record is ever removed the audit
 * entry must survive. In practice users are only deactivated,
 * but the nullable FK makes the table resilient either way.
 *
 * entityId is String (not a typed FK) because it must hold both
 * UUID strings (FinancialRecord, User) and integers.
 *
 * oldValue / newValue store row snapshots for change reconstruction.
 * oldValue is null on CREATE. newValue is null on DELETE.
 */
model AuditLog {
  id         BigInt  @id @default(autoincrement())
  userId     String? // optional — see comment above
  user       User?   @relation(fields: [userId], references: [id])

  action     String  // CREATE_RECORD | UPDATE_RECORD | DELETE_RECORD
             		  // UPDATE_USER_ROLE | UPDATE_USER_STATUS
             		  // BULK_IMPORT_RECORD | BULK_IMPORT_COMPLETE
  entityType String  // FinancialRecord | User
  entityId   String  // holds UUID strings

  oldValue   Json?
  newValue   Json?

  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ImportJob
// Tracks the lifecycle of a bulk financial record import.
//
// fileBuffer stores the raw uploaded file so the async queue worker
// can retrieve and process it without needing a filesystem or object store.
// In production this would be an S3 key — the buffer would live in object
// storage and only the reference would be stored here.
//
// errorLog stores the full array of row-level validation errors as JSON.
// For files within the 50MB cap this is acceptable. In production with
// very large files this would move to a separate table or S3 object.
//
// mode is stored as a string so the async worker knows which processing
// mode was requested at upload time (atomic vs partial).
model ImportJob {
  id         String          @id @default(uuid())
  uploadedBy String
  user       User            @relation(fields: [uploadedBy], references: [id])

  filename   String
  fileBuffer Bytes
  mimetype   String

  status      ImportJobStatus @default(PENDING)
  mode        String          @default("atomic")

  totalRows   Int  @default(0)
  savedCount  Int  @default(0)
  failedCount Int  @default(0)

  errorLog Json?

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([uploadedBy])
  @@index([status])
  @@index([createdAt])
}
