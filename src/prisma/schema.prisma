generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Role drives all access control — three fixed levels, no dynamic creation
enum Role {
  ADMIN
  ANALYST
  VIEWER
}

// Controls whether a user can authenticate — I check this in authenticate middleware on every request
enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// Amount is always stored as positive — type tells me which direction the money moved
enum TransactionType {
  INCOME
  EXPENSE
}

// Lifecycle of an async import job
enum ImportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id                 String     @id @default(uuid())
  username           String     @unique
  email              String     @unique
  passwordHash       String
  role               Role       @default(VIEWER)
  status             UserStatus @default(ACTIVE)
  mustChangePassword Boolean    @default(false)
  lastLogin          DateTime?  // null means never logged in

  records    FinancialRecord[]
  auditLogs  AuditLog[]
  importJobs ImportJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([status])
}

model FinancialRecord {
  id             String          @id @default(uuid())
  transactionRef String?         @unique // caller-supplied dedup key — prevents the same transaction being entered twice
  amount         Decimal         @db.Decimal(19, 4)
  type           TransactionType
  category       String          // free-form, e.g. "Salary", "Transport" — no FK, keeps aggregation queries simple
  transactionDate DateTime       // no default 
  description    String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  deletedAt DateTime? // soft delete — null means active

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([transactionDate])
  @@index([createdById])
  @@index([category])
  @@index([deletedAt])
  @@index([type])
  @@index([transactionRef])
}

// Append-only — no one never update or delete audit rows
// userId is nullable so audit entries survive even if the user is ever removed
// entityId is a String (not a typed FK) because it holds UUIDs from multiple tables
model AuditLog {
  id         BigInt  @id @default(autoincrement())
  userId     String?
  user       User?   @relation(fields: [userId], references: [id])

  action     String  // CREATE_RECORD | UPDATE_RECORD | DELETE_RECORD | UPDATE_USER_ROLE | UPDATE_USER_STATUS | BULK_IMPORT_RECORD | BULK_IMPORT_COMPLETE
  entityType String  // FinancialRecord | User
  entityId   String

  oldValue  Json? // null on CREATE
  newValue  Json? // null on DELETE

  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// here we store the raw file buffer here so the async worker can process it without needing S3 or disk.
// In production I'd store an S3 key instead and stream the file from there.
// Processing is always atomic — if any row fails, nothing is saved and the job goes to FAILED.
model ImportJob {
  id         String          @id @default(uuid())
  uploadedBy String
  user       User            @relation(fields: [uploadedBy], references: [id])

  filename   String
  fileBuffer Bytes
  mimetype   String

  status      ImportJobStatus @default(PENDING)

  totalRows   Int  @default(0)
  savedCount  Int  @default(0)
  failedCount Int  @default(0)

  errorLog Json? // full row-level error array when status is FAILED

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([uploadedBy])
  @@index([status])
  @@index([createdAt])
}
